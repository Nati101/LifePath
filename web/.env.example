# Copy to .env.local and fill in your values
# Next.js does NOT read .env.example — only .env.local

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Optional: Supabase's newer key name (either this or ANON_KEY works)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only — never prefix with NEXT_PUBLIC_
# SUPABASE_SECRET_KEY=sb_secret_...

# Set to /LifePath when deploying to https://nati101.github.io/LifePath
NEXT_PUBLIC_BASE_PATH=

# Public site URL (used for auth redirects)
# Local: http://localhost:3000
# GitHub Pages: https://nati101.github.io/LifePath
NEXT_PUBLIC_SITE_URL=http://localhost:3000
